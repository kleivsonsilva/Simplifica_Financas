# ─── JWT (CRÍTICO: MESMO VALOR EM TODOS OS SERVIÇOS) ─────────────
# Gere com: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=troque-este-segredo-em-producao-use-openssl-rand-hex-32

# ─── MONGODB ──────────────────────────────────────────────────────
MONGO_USER=admin
MONGO_PASSWORD=simplifica2025

# ─── POSTGRES ─────────────────────────────────────────────────────
POSTGRES_DB=simplifica_auth
POSTGRES_USER=admin
POSTGRES_PASSWORD=simplifica2025

# ─── REDIS ────────────────────────────────────────────────────────
REDIS_PASSWORD=simplifica2025

# ─── RABBITMQ ─────────────────────────────────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASS=simplifica2025
